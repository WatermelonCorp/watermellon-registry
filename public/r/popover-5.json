assName=\"text-[11px] font-medium tracking-tight text-neutral-400 dark:text-neutral-600\">\r\n              Released as build 2.0.4-stable\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </PopoverContent>\r\n    </Popover>\r\n  );\r\n};\r\n\r\nexport default Popover5;\r\n",
